<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutt9numeric"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:orientation="vertical"
        android:paddingTop="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:text="%"
                style="@style/KeyButton.Func" />

            <Button
                android:text="1"
                style="@style/KeyButton" />

            <Button
                android:text="2"
                style="@style/KeyButton" />

            <Button
                android:text="3"
                style="@style/KeyButton" />

            <Button
                android:id="@+id/t9numdel"
                android:text="⌫"
                style="@style/KeyButton.Func" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:text="/"
                style="@style/KeyButton.Func" />

            <Button
                android:text="4"
                style="@style/KeyButton" />

            <Button
                android:text="5"
                style="@style/KeyButton" />

            <Button
                android:text="6"
                style="@style/KeyButton" />

            <Button
                android:text="."
                style="@style/KeyButton.Func" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:text="-"
                style="@style/KeyButton.Func" />

            <Button
                android:text="7"
                style="@style/KeyButton" />

            <Button
                android:text="8"
                style="@style/KeyButton" />

            <Button
                android:text="9"
                style="@style/KeyButton" />

            <Button
                android:text="\\@"
                style="@style/KeyButton.FuncSmallText" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <Button
                android:text="+"
                style="@style/KeyButton.Func" />

            <Button
                android:id="@+id/t9numback"
                android:text="返回"
                style="@style/KeyButton.FuncSmallText" />

            <Button
                android:text="0"
                style="@style/KeyButton" />

            <Button
                android:text="␣"
                style="@style/KeyButton.SmallText" />

            <Button
                android:text="⏎"
                style="@style/KeyButton.Func" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
