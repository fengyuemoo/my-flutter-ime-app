<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/panelSymbolsRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Body: left scrollable grid + right fixed action column -->
    <LinearLayout
        android:id="@+id/symbolBody"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:orientation="horizontal">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/symbolRecycler"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="4"
            android:overScrollMode="never"
            android:padding="6dp" />

        <LinearLayout
            android:id="@+id/symbolActionColumn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="6dp">

            <Button
                android:id="@+id/btnSymBack"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="返回"
                style="@style/KeyButton" />

            <Button
                android:id="@+id/btnSymUp"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="︿"
                style="@style/KeyButton" />

            <Button
                android:id="@+id/btnSymDown"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="﹀"
                style="@style/KeyButton" />

            <Button
                android:id="@+id/btnSymLock"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="🔓"
                style="@style/KeyButton" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom tabs: horizontal scroll, no auto-centering -->
    <HorizontalScrollView
        android:id="@+id/symbolTabScroll"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/symbolTabContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="6dp"
            android:paddingEnd="6dp" />
    </HorizontalScrollView>
</LinearLayout>
