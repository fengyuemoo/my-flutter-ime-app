<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/panelSymbolsRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Body: left scrollable grid + right fixed action column -->
    <LinearLayout
        android:id="@+id/symbolBody"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:orientation="horizontal">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/symbolRecycler"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="4"
            android:overScrollMode="never"
            android:padding="4dp" />

        <LinearLayout
            android:id="@+id/symbolActionColumn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="4dp">

            <Button
                android:id="@+id/btnSymBack"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="返回"
                style="@style/KeyButton" />

            <Button
                android:id="@+id/btnSymUp"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="︿"
                style="@style/KeyButton" />

            <Button
                android:id="@+id/btnSymDown"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="﹀"
                style="@style/KeyButton" />

            <Button
                android:id="@+id/btnSymLock"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="🔓"
                style="@style/KeyButton" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom tabs -->
    <LinearLayout
        android:id="@+id/symbolTabs"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/tabCommon"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Common"
            style="@style/KeyButton" />

        <Button
            android:id="@+id/tabCn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="中文"
            style="@style/KeyButton" />

        <Button
            android:id="@+id/tabEn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="English"
            style="@style/KeyButton" />
    </LinearLayout>
</LinearLayout>
