<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/maincontent"
    android:layout_width="match_parent"
    android:layout_height="@dimen/ime_ime_window_height"
    android:background="@color/ime_panel_bg"
    android:clipChildren="false"
    android:clipToPadding="false">

    <FrameLayout
        android:id="@+id/imeareastack"
        android:layout_width="match_parent"
        android:layout_height="@dimen/ime_keyboard_total_height"
        android:layout_gravity="bottom"
        android:clipChildren="false"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/contentcolumn"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingBottom="0dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <FrameLayout
                android:id="@+id/topbarframe"
                android:layout_width="match_parent"
                android:layout_height="@dimen/ime_topbar_height"
                android:background="@color/ime_toolbar_bg">

                <LinearLayout
                    android:id="@+id/toolbarcontainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp">

                    <Button
                        android:id="@+id/btntoollayout"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="⌨"
                        android:textSize="@dimen/ime_toolbar_button_text_size"
                        style="@style/KeyButton.Func"
                        android:layout_marginEnd="5dp" />

                    <!-- NEW: 字体/字号按钮（图标在 ImeUi.kt 里运行时设置；这里给一个占位 src） -->
                    <ImageButton
                        android:id="@+id/btntoolfont"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginStart="5dp"
                        android:layout_marginEnd="5dp"
                        android:background="@drawable/ripple_ime_key_func"
                        android:contentDescription="字体/字号"
                        android:padding="8dp"
                        android:scaleType="centerInside"
                        android:src="@android:drawable/ic_menu_edit" />

                    <Button
                        android:id="@+id/btntooltheme"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="🎨"
                        android:textSize="@dimen/ime_toolbar_button_text_size"
                        style="@style/KeyButton.Func"
                        android:layout_marginStart="5dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/candidatestrip"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:background="@color/ime_surface"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:elevation="2dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclercandidateshorizontal"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:scrollbars="none" />

                    <ImageButton
                        android:id="@+id/btnexpandcandidates"
                        android:layout_width="50dp"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_chevron_down"
                        android:background="?android:attr/selectableItemBackground"
                        android:scaleType="centerInside"
                        android:padding="12dp"
                        android:contentDescription="展开" />
                </LinearLayout>

            </FrameLayout>

            <FrameLayout
                android:id="@+id/keyboardoverlaycontainer"
                android:layout_width="match_parent"
                android:layout_height="@dimen/ime_keyboard_body_height">

                <FrameLayout
                    android:id="@+id/keyboardbodyframe"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </FrameLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/expandedcandidatespanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:background="@color/ime_surface"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            android:elevation="8dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclercandidatesvertical"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:padding="0dp" />

            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@color/ime_panel_bg"
                android:padding="2dp">

                <ImageButton
                    android:id="@+id/expandpanelclose"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:src="@drawable/ic_chevron_down"
                    android:rotation="180"
                    android:background="?android:attr/selectableItemBackground"
                    android:scaleType="centerInside"
                    android:contentDescription="关闭" />

                <Button
                    android:id="@+id/expandpaneldel"
                    android:text="⌫"
                    style="@style/KeyButton.Func"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <Button
                    android:id="@+id/expandpanelreenter"
                    android:text="重输"
                    style="@style/KeyButton.FuncSmallText"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <Button
                    android:id="@+id/expandpanelfilter"
                    android:text="全部/单字"
                    style="@style/KeyButton.FuncSmallText"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />
            </LinearLayout>
        </LinearLayout>

    </FrameLayout>

    <!-- 悬浮 preedit：在“上浮区”里；通过增大 ime_preedit_float_height 让它完全不碰候选条 -->
    <TextView
        android:id="@+id/tvcomposingpreview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start|top"
        android:layout_marginStart="8dp"
        android:layout_marginTop="4dp"
        android:background="@color/ime_surface"
        android:paddingLeft="6dp"
        android:paddingRight="6dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:textColor="@color/ime_accent"
        android:textSize="@dimen/ime_composing_text_size"
        android:textStyle="bold"
        android:singleLine="true"
        android:ellipsize="end"
        android:maxWidth="320dp"
        android:alpha="0.78"
        android:elevation="12dp"
        android:visibility="gone" />

</FrameLayout>
